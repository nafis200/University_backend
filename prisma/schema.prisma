generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // url   = env("DATABASE_URL")
}

model User {
  gstApplicationId  String     @id @default(uuid()) 
  password          String
  role              UserRole
  status            UserStatus @default(ACTIVE)
  unit              String     @default("default unit") 
  faculty           String?    // optional
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@map("users")
}






enum UserRole {
  STUDENTS
  ADMIN
  FACULTY
  DEAN
  REGISTER
  HALL_REGISTER
}


enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}
